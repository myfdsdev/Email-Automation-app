# ------------------------------------------------------------------
# Email Automation - environment variables
# Copy to server/.env (backend) - never commit real values.
# ------------------------------------------------------------------

NODE_ENV=development
PORT=5000

CLIENT_URL=http://localhost:5173
API_URL=http://localhost:5000

# MongoDB connection string. For local dev without MongoDB installed you
# can set USE_MEMORY_DB=true instead (uses mongodb-memory-server).
MONGODB_URI=mongodb://127.0.0.1:27017/email-automation
USE_MEMORY_DB=false

# Auth secrets (generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
COOKIE_SECRET=

# Google OAuth (Gmail integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/integrations/gmail/callback
GOOGLE_PUBSUB_TOPIC=
GOOGLE_PUBSUB_SUBSCRIPTION=

# Brevo (per-workspace API keys are stored encrypted in DB; these are optional global defaults)
BREVO_API_KEY=
BREVO_WEBHOOK_SECRET=

# 32-byte hex key used for AES-256-GCM encryption of Gmail tokens / Brevo keys.
# MUST be exactly 64 hex characters; the server refuses to boot in production otherwise.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Back this up. If it is lost, every stored Gmail/Brevo credential becomes
# undecryptable and all integrations must be reconnected by hand.
EMAIL_CREDENTIAL_ENCRYPTION_KEY=

# Cookie behaviour. Leave unset for same-origin deploys (the API serves the SPA) -
# defaults to 'lax', which also lets the Gmail OAuth return redirect carry the session.
# Set to 'none' ONLY when the SPA is on a different domain than the API (requires HTTPS).
COOKIE_SAMESITE=
# Optional: share cookies across subdomains, e.g. .example.com
COOKIE_DOMAIN=

# Serve the built client (client/dist) from the API process. Defaults to true when
# NODE_ENV=production. Set false if a CDN/static host serves the frontend instead.
SERVE_CLIENT=

# Redis (required for background workers / BullMQ). Web API degrades gracefully without it.
REDIS_URL=redis://127.0.0.1:6379
RUN_WORKERS=false

# AI features (OpenAI-compatible). Optional - a heuristic classifier is used as fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Stripe billing (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Cloudinary (optional - attachment/file uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Transactional system mail (verification / password reset). If SMTP is not
# configured, emails are logged to the console in development.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Email Automation <no-reply@localhost>"
